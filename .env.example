# myCLEO Expo environment variables
#
# Copy this file to .env (or .env.local) and adjust values.
# Only EXPO_PUBLIC_* vars are bundled into the client build.

# Where the FastAPI bridge is reachable from the device.
#  - WSL2 dev (Expo Go on the same machine): leave default
#  - Phone over Tailscale: set to http://<tailscale-ip>:8765
#                          (Ivan's WSL host: http://100.64.218.73:8765)
EXPO_PUBLIC_BRIDGE_URL=http://127.0.0.1:8765

# Bridge auth API key — must match CLEO_BRIDGE_API_KEY in Doppler CLEO/dev.
# Set in expo-secure-store on first launch (IVA-899); env var is dev fallback.
# EXPO_PUBLIC_BRIDGE_API_KEY=
