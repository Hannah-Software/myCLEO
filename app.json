{
  "expo": {
    "name": "myCLEO",
    "slug": "my-cleo",
    "version": "0.0.1",
    "scheme": "mycleo",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.synapticsystems.mycleo"
    },
    "android": {
      "package": "com.synapticsystems.mycleo",
      "supportedAbis": [
        "armeabi-v7a",
        "arm64-v8a",
        "x86",
        "x86_64"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "4f6ef6c3-4b6a-4e84-9d42-885824a69e81"
      },
      "router": {
        "origin": false
      }
    },
    "owner": "ivanemadrigal"
  }
}
