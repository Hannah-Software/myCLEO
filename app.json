{
  "expo": {
    "name": "myCLEO",
    "slug": "my-cleo",
    "version": "0.0.1",
    "scheme": "mycleo",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": ["**/*"],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.synapticsystems.mycleo"
    },
    "android": {
      "package": "com.synapticsystems.mycleo",
      "supportedAbis": ["armeabi-v7a", "arm64-v8a", "x86", "x86_64"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      ["expo-sqlite"],
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      }
    }
  }
}
